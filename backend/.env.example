# ============================================
# Ignum CFO v2.0 - Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ignum_cfo

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
MEK_HASH=your-master-encryption-key-for-hsm-simulation

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_SETUP=price_setup_fee
STRIPE_PRICE_GODINEZ=price_999_monthly
STRIPE_PRICE_EMPRESARIO=price_5300_monthly
STRIPE_PRICE_SOVEREIGN=price_11000_monthly

# Email (Resend)
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=noreply@ignum.cfo

# WebAuthn
RP_ID=ignum-cfo.vercel.app
RP_NAME=Ignum CFO

# Frontend URL
FRONTEND_URL=https://ignum-cfo.vercel.app

# SAT Integration
SAT_WSDL_URL=https://consultaqr.facturaelectronica.sat.gob.mx/ConsultaCFDIService.svc

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Environment
ENV=development
